---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import { breadcrumb } from '../lib/schema';

const schema = breadcrumb('FAQ', '/faq');
---

<BaseLayout
  title="FAQ - Najczęściej zadawane pytania | Agencja SEO Talem"
  description="Odpowiedzi na najczęściej zadawane pytania dotyczące współpracy z naszą butikową agencją SEO. Dowiedz się więcej o naszym podejściu, efektach działań i warunkach współpracy."
  schema={schema}
>
  <Navigation />

  <section
    class="relative min-h-[40vh] flex items-center px-4 sm:px-6 lg:px-8 pt-32 pb-16 overflow-hidden bg-white"
  >
    <div class="max-w-[1400px] mx-auto w-full relative z-[2]">
      <span
        class="inline-flex items-center gap-2 font-mono text-[0.85rem] font-semibold tracking-[0.1em] uppercase mb-6 text-gray-500"
      >
        <span class="text-accent">TALEM</span> / FAQ
      </span>
      <h1
        class="font-display text-[clamp(2rem,6vw,3.5rem)] font-black leading-[1.1] tracking-[-0.03em] mb-6"
      >
        Najczęściej <span
          class="text-accent relative inline-block after:content-[''] after:absolute after:bottom-[0.2em] after:left-[-0.1em] after:right-[-0.1em] after:h-[0.15em] after:bg-accent after:opacity-20 after:-z-[1] tracking-normal"
          >zadawane pytania</span
        >
      </h1>
      <p class="text-[1.125rem] leading-[1.8] text-gray-500 w-full">
        Odpowiedzi na najważniejsze pytania dotyczące współpracy z butikową agencją SEO Talem.
      </p>
    </div>

    <!-- Background grid -->
    <div class="absolute inset-0 z-[1] opacity-40">
      <div
        class="w-full h-full bg-[linear-gradient(to_right,rgba(229,229,229,1)_1px,transparent_1px),linear-gradient(to_bottom,rgba(229,229,229,1)_1px,transparent_1px)] bg-[size:40px_40px] [mask-image:radial-gradient(ellipse_at_center,black_20%,transparent_80%)]"
      >
      </div>
    </div>
  </section>

  <section class="px-4 sm:px-6 lg:px-8 py-16 bg-white">
    <div class="max-w-[860px] mx-auto">
      <div class="space-y-12">
        <div>
          <h2 class="font-display text-[1.5rem] font-bold mb-4 flex items-center gap-3">
            <span
              class="font-mono text-[0.75rem] font-semibold tracking-[0.1em] uppercase text-accent border border-accent/30 rounded px-2 py-1"
              >01</span
            >
            Czym różnicie się od innych agencji SEO?
          </h2>
          <p class="text-[1.0625rem] leading-[1.85] text-gray-600">
            Działamy w modelu butikowym – współpracujemy z ograniczoną liczbą klientów, dzięki czemu
            możemy poświęcić każdemu projektowi realny czas i uwagę. Nie oferujemy gotowych pakietów
            – każda strategia jest dopasowana do konkretnego biznesu, jego danych i celów.
          </p>
        </div>

        <div class="border-t border-gray-100 pt-12">
          <h2 class="font-display text-[1.5rem] font-bold mb-4 flex items-center gap-3">
            <span
              class="font-mono text-[0.75rem] font-semibold tracking-[0.1em] uppercase text-accent border border-accent/30 rounded px-2 py-1"
              >02</span
            >
            Ile trwa osiągnięcie efektów SEO?
          </h2>
          <p class="text-[1.0625rem] leading-[1.85] text-gray-600">
            SEO to proces długoterminowy. Pierwsze efekty pojawiają się po kilku miesiącach,
            natomiast stabilny wzrost widoczności i sprzedaży następuje w okresie 6-12 miesięcy i
            jest kontynuowany w kolejnych miesiącach.
          </p>
        </div>

        <div class="border-t border-gray-100 pt-12">
          <h2 class="font-display text-[1.5rem] font-bold mb-4 flex items-center gap-3">
            <span
              class="font-mono text-[0.75rem] font-semibold tracking-[0.1em] uppercase text-accent border border-accent/30 rounded px-2 py-1"
              >03</span
            >
            Jak mierzycie efekty działań?
          </h2>
          <p class="text-[1.0625rem] leading-[1.85] text-gray-600">
            Nie skupiamy się tylko na pozycjach w Google. Nasze działania ukierunkowane są na:
          </p>
          <ul class="mt-4 space-y-2 text-[1.0625rem] leading-[1.85] text-gray-600">
            <li class="flex items-start gap-3">
              <span class="text-accent mt-1">•</span>
              <span>wzrost ruchu organicznego,</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-accent mt-1">•</span>
              <span>jakość ruchu,</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-accent mt-1">•</span>
              <span>konwersje i sprzedaż,</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-accent mt-1">•</span>
              <span>widoczność całego serwisu.</span>
            </li>
          </ul>
        </div>

        <div class="border-t border-gray-100 pt-12">
          <h2 class="font-display text-[1.5rem] font-bold mb-4 flex items-center gap-3">
            <span
              class="font-mono text-[0.75rem] font-semibold tracking-[0.1em] uppercase text-accent border border-accent/30 rounded px-2 py-1"
              >04</span
            >
            Jak wygląda współpraca?
          </h2>
          <p class="text-[1.0625rem] leading-[1.85] text-gray-600">
            Nad projektem pracuje zespół specjalistów (technicznych, contentowych, analitycznych).
            Działamy blisko z klientem, często jako przedłużenie jego zespołu. Stawiamy na
            komunikację, transparentność i wspólne cele.
          </p>
        </div>

        <div class="border-t border-gray-100 pt-12">
          <h2 class="font-display text-[1.5rem] font-bold mb-4 flex items-center gap-3">
            <span
              class="font-mono text-[0.75rem] font-semibold tracking-[0.1em] uppercase text-accent border border-accent/30 rounded px-2 py-1"
              >05</span
            >
            Czy wykorzystujecie AI w działaniach SEO?
          </h2>
          <p class="text-[1.0625rem] leading-[1.85] text-gray-600">
            Tak. Wykorzystujemy automatyzację oraz narzędzia oparte na AI m.in. w analizie danych,
            procesach contentowych i optymalizacji. Dzięki temu działamy szybciej i skuteczniej,
            zachowując wysoką jakość.
          </p>
        </div>

        <div class="border-t border-gray-100 pt-12">
          <h2 class="font-display text-[1.5rem] font-bold mb-4 flex items-center gap-3">
            <span
              class="font-mono text-[0.75rem] font-semibold tracking-[0.1em] uppercase text-accent border border-accent/30 rounded px-2 py-1"
              >06</span
            >
            Czy wasze SEO gwarantuje sprzedaż?
          </h2>
          <p class="text-[1.0625rem] leading-[1.85] text-gray-600">
            SEO zwiększa widoczność i sprowadza wartościowy ruch, ale sprzedaż zależy również od
            oferty, UX, ceny i strategii biznesowej. Dlatego patrzymy na projekt szeroko – nie tylko
            przez pryzmat ruchu.
          </p>
        </div>

        <div class="border-t border-gray-100 pt-12">
          <h2 class="font-display text-[1.5rem] font-bold mb-4 flex items-center gap-3">
            <span
              class="font-mono text-[0.75rem] font-semibold tracking-[0.1em] uppercase text-accent border border-accent/30 rounded px-2 py-1"
              >07</span
            >
            Czy oferujecie strategię dopasowaną do mojego biznesu?
          </h2>
          <p class="text-[1.0625rem] leading-[1.85] text-gray-600">
            Tak. To fundament naszej pracy. Każdy projekt zaczynamy od analizy danych, rynku i
            potencjału, a następnie budujemy indywidualną strategię działania dopasowaną do
            charakteru biznesu, zakładanych celów i posiadanego budżetu.
          </p>
        </div>

        <div class="border-t border-gray-100 pt-12">
          <h2 class="font-display text-[1.5rem] font-bold mb-4 flex items-center gap-3">
            <span
              class="font-mono text-[0.75rem] font-semibold tracking-[0.1em] uppercase text-accent border border-accent/30 rounded px-2 py-1"
              >08</span
            >
            Jak długo działacie na rynku SEO?
          </h2>
          <p class="text-[1.0625rem] leading-[1.85] text-gray-600">
            Istniejemy nieprzerwanie od 2006 roku. Od początku działamy w branży SEO. Jesteśmy
            najdłużej istniejącą agencją SEO w Bydgoszczy.
          </p>
        </div>

        <div class="border-t border-gray-100 pt-12">
          <h2 class="font-display text-[1.5rem] font-bold mb-4 flex items-center gap-3">
            <span
              class="font-mono text-[0.75rem] font-semibold tracking-[0.1em] uppercase text-accent border border-accent/30 rounded px-2 py-1"
              >09</span
            >
            Na czym polega Wasze „butikowe" podejście w praktyce?
          </h2>
          <p class="text-[1.0625rem] leading-[1.85] text-gray-600">
            Pracujemy z ograniczoną liczbą klientów, stawiamy na jakość, a nie ilość. Dzięki temu
            możemy szybko reagować na zmiany i realnie wpływać na rozwój sklepu poświęcając mu tyle
            czasu ile potrzeba. Każdego klienta traktujemy jak partnera biznesowego, wchodzimy
            głęboko w jego biznes i branżę. Działamy jak przedłużenie zespołu, wspólnie planując
            kierunki rozwoju sklepu.
          </p>
        </div>

        <div class="border-t border-gray-100 pt-12">
          <h2 class="font-display text-[1.5rem] font-bold mb-4 flex items-center gap-3">
            <span
              class="font-mono text-[0.75rem] font-semibold tracking-[0.1em] uppercase text-accent border border-accent/30 rounded px-2 py-1"
              >10</span
            >
            Czy macie cennik usług SEO?
          </h2>
          <p class="text-[1.0625rem] leading-[1.85] text-gray-600">
            Nie pracujemy na stałym cenniku usług czy sztywnych pakietach; każdą współpracę
            poprzedza rozmowa i analiza projektu, a budżet jest dostosowany do potrzebnych nakładów
            prac do osiągnięcia zakładanych celów.
          </p>
        </div>

        <div class="border-t border-gray-100 pt-12">
          <h2 class="font-display text-[1.5rem] font-bold mb-4 flex items-center gap-3">
            <span
              class="font-mono text-[0.75rem] font-semibold tracking-[0.1em] uppercase text-accent border border-accent/30 rounded px-2 py-1"
              >11</span
            >
            Jaki budżet jest potrzebny na SEO?
          </h2>
          <p class="text-[1.0625rem] leading-[1.85] text-gray-600">
            Jest to zależne od skali projektu, konkurencyjności branży i celów biznesowych.
            Minimalny budżet w którym można osiągnąć zadowalające efekty i podstawowe cele to kwota
            około 2000 zł miesięcznie.
          </p>
        </div>

        <div class="border-t border-gray-100 pt-12">
          <h2 class="font-display text-[1.5rem] font-bold mb-4 flex items-center gap-3">
            <span
              class="font-mono text-[0.75rem] font-semibold tracking-[0.1em] uppercase text-accent border border-accent/30 rounded px-2 py-1"
              >12</span
            >
            Jak mierzycie efekty działań SEO?
          </h2>
          <p class="text-[1.0625rem] leading-[1.85] text-gray-600">
            Skupiamy się na twardych wskaźnikach: wzroście widoczności w Google, ruchu organicznego
            oraz sprzedaży, a nie wyłącznie na wybranych pozycjach fraz.
          </p>
        </div>

        <div class="border-t border-gray-100 pt-12">
          <h2 class="font-display text-[1.5rem] font-bold mb-4 flex items-center gap-3">
            <span
              class="font-mono text-[0.75rem] font-semibold tracking-[0.1em] uppercase text-accent border border-accent/30 rounded px-2 py-1"
              >13</span
            >
            Jak zacząć współpracę?
          </h2>
          <p class="text-[1.0625rem] leading-[1.85] text-gray-600">
            Pierwszym krokiem jest rozmowa i analiza projektu. Na tej podstawie określamy potencjał
            SEO oraz proponujemy kierunek działań.
          </p>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
