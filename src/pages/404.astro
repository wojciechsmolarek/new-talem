---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="404 – Strona nie została odnaleziona | Agencja SEO Talem"
  description="Strona, której szukasz, nie istnieje lub została przeniesiona pod nowy adres."
>
  <Navigation />

  <section
    class="relative min-h-[100vh] flex items-center px-4 sm:px-6 lg:px-8 pt-32 pb-16 overflow-hidden bg-white"
  >
    <div class="max-w-[1400px] mx-auto w-full relative z-[2]">
      <div class="max-w-[700px]">

        <span class="font-mono text-[0.75rem] font-semibold tracking-[0.1em] uppercase text-accent mb-6 block">
          Błąd 404
        </span>

        <h1 class="font-display text-[clamp(2.5rem,7vw,4.5rem)] font-black leading-[1.1] tracking-[-0.03em] mb-8">
          Strona nie została<br />
          <span class="text-accent italic">odnaleziona.</span>
        </h1>

        <p class="text-[1rem] lg:text-[1.25rem] leading-[1.8] text-gray-600 mb-12 max-w-[560px]">
          Ścieżka, którą podążasz, już nie istnieje lub została przeniesiona pod nowy adres.
          Sprawdź, czy adres URL jest poprawny, lub skorzystaj z poniższych opcji.
        </p>

        <div class="flex gap-4 flex-wrap">
          <a
            href="/"
            class="inline-flex items-center justify-center gap-3 px-8 py-4 rounded-lg font-semibold transition text-base bg-black text-white border-2 border-black hover:bg-accent hover:border-accent hover:shadow-xl"
          >
            Wróć do strony głównej
            <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M5 12h14M12 5l7 7-7 7"></path>
            </svg>
          </a>
          <a
            href="/#uslugi"
            class="inline-flex items-center justify-center px-8 py-4 rounded-lg font-semibold transition text-base bg-transparent text-black border-2 border-gray-300 hover:border-black hover:bg-black hover:text-white"
          >
            Nasze usługi
          </a>
        </div>

      </div>
    </div>

    <!-- Decorative 404 -->
    <div
      aria-hidden="true"
      class="hidden lg:flex absolute right-0 top-1/2 -translate-y-1/2 items-center justify-center w-[55%] select-none pointer-events-none"
    >
      <span class="font-display font-black text-[22rem] leading-none text-black opacity-[0.04]">404</span>
    </div>

    <!-- Background grid -->
    <div class="absolute inset-0 z-[1] opacity-40">
      <div
        class="w-full h-full bg-[linear-gradient(to_right,rgba(229,229,229,1)_1px,transparent_1px),linear-gradient(to_bottom,rgba(229,229,229,1)_1px,transparent_1px)] bg-[size:40px_40px] [mask-image:radial-gradient(ellipse_at_center,black_20%,transparent_80%)]"
      ></div>
    </div>
  </section>

  <Footer />
</BaseLayout>
