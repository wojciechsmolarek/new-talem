---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
import AboutUsContact from '../components/about-us/AboutUsContact.astro';

const currentYear = new Date().getFullYear();
const foundingYear = 2006;
const yearsOfExperience = currentYear - foundingYear;

const values = [
  {
    icon: '<path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />',
    title: 'Jakość ponad ilość',
    desc: 'Pracujemy z ograniczoną liczbą klientów, by każdemu zapewnić pełne zaangażowanie zespołu.',
  },
  {
    icon: '<path d="M13 10V3L4 14h7v7l9-11h-7z" />',
    title: 'Dane, nie domysły',
    desc: 'Każda decyzja oparta jest na twardych danych. Mierzymy, analizujemy, optymalizujemy.',
  },
  {
    icon: '<path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />',
    title: 'Partnerstwo',
    desc: 'Traktujemy każdy projekt jak wspólny cel. Wasz sukces to nasz sukces.',
  },
  {
    icon: '<path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />',
    title: 'Innowacyjność',
    desc: 'Wykorzystujemy AI i automatyzacje, by być o krok przed konkurencją.',
  },
];

const funFacts = [
  { number: '2137', label: 'Litrów kawy wypitych', icon: '☕' },
  { number: '∞', label: 'Godzin w Google Search Console', icon: '📊' },
  { number: '42', label: 'Odpowiedź na wszystko', icon: '🤓' },
  { number: '1', label: 'Kaktus w biurze (przeżył!)', icon: '🌵' },
];
---

<BaseLayout
  title="O nas | TALEM - Agencja SEO"
  description="Poznaj zespół TALEM. Od 2006 roku pomagamy sklepom internetowym rosnąć w wyszukiwarkach. Butikowe podejście, mierzalne wyniki."
>
  <Navigation />

  <!-- Hero Section -->
  <section
    class="relative min-h-[70vh] flex items-center px-4 sm:px-6 lg:px-8 pt-32 pb-16 overflow-hidden bg-white"
  >
    <div class="max-w-[1400px] mx-auto w-full relative z-[2]">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <h1
            class="inline-flex items-center gap-2 font-mono text-[1.25rem] font-semibold tracking-[0.1em] uppercase mb-8 text-gray-600"
          >
            <span class="text-accent">Poznaj</span> Nas
          </h1>
          <p
            class="font-display text-[clamp(2rem,7vw,4rem)] font-black leading-[1.1] tracking-[-0.03em] mb-8"
          >
            Butikowa agencja SEO<br />
            <span
              class="text-accent relative inline-block after:content-[''] after:absolute after:bottom-[0.2em] after:left-[-0.1em] after:right-[-0.1em] after:h-[0.15em] after:bg-accent after:opacity-20 after:-z-[1] tracking-normal"
            >
              od 2006 roku</span
            >
          </p>
          <p class="text-[1.125rem] lg:text-[1.25rem] leading-[1.8] text-gray-600 mb-12 w-full">
            Talem to butikowa agencja SEO wyspecjalizowana w działaniach dla projektów e-commerce.
            Świadomie pracujemy z wybraną grupą klientów, ponieważ wierzymy, że skuteczne SEO wymaga
            czasu, dokładnej analizy i regularnej optymalizacji — a nie masowej obsługi projektów
            realizowanych według jednego schematu.
          </p>
          <p class="text-[1.125rem] lg:text-[1.25rem] leading-[1.8] text-gray-600 mb-12 w-full">
            Dzięki temu możemy realnie wpływać na rozwój sklepów internetowych i budować ich
            długoterminową widoczność w Google.
          </p>
          <div class="flex gap-4 flex-wrap">
            <a
              href="#kontakt"
              class="inline-flex items-center justify-center min-w-[200px] px-8 py-4 rounded-lg font-semibold transition text-base bg-transparent text-black border-2 border-gray-300 hover:border-black hover:bg-black hover:text-white"
            >
              Porozmawiajmy
            </a>
          </div>
        </div>

        <!-- Stats Cards -->
        <div class="flex flex-col gap-6 w-full lg:max-w-[400px] ml-auto">
          <div
            class="bg-white border-2 border-gray-200 rounded-xl p-6 transition-all hover:border-accent hover:-translate-y-1 hover:shadow-xl"
            data-reveal
          >
            <div class="font-mono text-[0.75rem] uppercase tracking-wider text-gray-500 mb-3">
              Lat doświadczenia
            </div>
            <div class="flex items-baseline">
              <div
                class="font-mono text-[3rem] font-bold leading-none text-black"
                data-count-to={yearsOfExperience}
              >
                {yearsOfExperience}
              </div>
              <div class="font-mono text-[1.5rem] font-bold text-accent ml-1">+</div>
            </div>
          </div>

          <div
            class="bg-white border-2 border-gray-200 rounded-xl p-6 transition-all hover:border-accent hover:-translate-y-1 hover:shadow-xl"
            data-reveal
          >
            <div class="font-mono text-[0.75rem] uppercase tracking-wider text-gray-500 mb-3">
              Zrealizowanych projektów
            </div>
            <div class="flex items-baseline">
              <div
                class="font-mono text-[3rem] font-bold leading-none text-black"
                data-count-to="250"
              >
                250
              </div>
              <div class="font-mono text-[1.5rem] font-bold text-accent ml-1">+</div>
            </div>
          </div>

          <div
            class="bg-white border-2 border-gray-200 rounded-xl p-6 transition-all hover:border-accent hover:-translate-y-1 hover:shadow-xl"
            data-reveal
          >
            <div class="font-mono text-[0.75rem] uppercase tracking-wider text-gray-500 mb-3">
              Średni czas współpracy
            </div>
            <div class="flex items-baseline">
              <div
                class="font-mono text-[3rem] font-bold leading-none text-black"
                data-count-to="4"
              >
                4
              </div>
              <div class="font-mono text-[1.5rem] font-bold text-accent ml-1">lata</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Background grid -->
    <div class="absolute inset-0 z-[1] opacity-40">
      <div
        class="w-full h-full bg-[linear-gradient(to_right,rgba(229,229,229,1)_1px,transparent_1px),linear-gradient(to_bottom,rgba(229,229,229,1)_1px,transparent_1px)] bg-[size:40px_40px] [mask-image:radial-gradient(ellipse_at_center,black_20%,transparent_80%)]"
      >
      </div>
    </div>
  </section>

  <!-- Mission Section -->
  <section class="bg-black text-white px-4 sm:px-6 lg:px-8 py-24 lg:py-32 relative overflow-hidden">
    <div class="max-w-[1400px] mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div data-reveal>
          <div
            class="font-mono text-[0.75rem] uppercase tracking-wider text-accent mb-6 font-semibold"
          >
            Nasza misja
          </div>
          <h2
            class="font-display text-[clamp(2rem,5vw,3.5rem)] font-black leading-[1.1] tracking-[-0.02em] mb-8 text-white"
          >
            Pomagamy polskim<br />
            e-commerce'om<br />
            <span class="text-accent">dominować</span> w Google
          </h2>
          <p class="text-[1.125rem] leading-[1.8] text-gray-300 mb-8">
            Wierzymy, że polskie sklepy internetowe mogą z powodzeniem konkurować z gigantami
            branży. Nie poprzez większe budżety, ale poprzez mądrzejsze strategie SEO oparte na
            danych i głębokim zrozumieniu e-commerce.
          </p>
          <p class="text-[1.125rem] leading-[1.8] text-gray-300">
            Nasza praca to nie tylko pozycjonowanie. To budowanie długoterminowej przewagi
            konkurencyjnej. Tworzymy fundamenty, które procentują latami.
          </p>
        </div>

        <!-- Decorative circles -->
        <div class="relative h-[400px] hidden lg:block">
          <div
            class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[300px] h-[300px] rounded-full border-2 border-accent/30"
          >
          </div>
          <div
            class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 translate-x-[30px] translate-y-[-20px] w-[200px] h-[200px] rounded-full bg-accent shadow-2xl"
          >
          </div>
          <div
            class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 translate-x-[-80px] translate-y-[60px] w-[120px] h-[120px] rounded-full border-2 border-accent/20"
          >
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Values Section -->
  <section class="bg-gray-100 px-4 sm:px-6 lg:px-8 py-24 lg:py-32">
    <div class="max-w-[1400px] mx-auto">
      <div class="text-center mb-16" data-reveal>
        <SectionHeader
          label="Nasze wartości"
          title="To, w co <span class='text-accent'>wierzymy</span>"
          centered
        />
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {
          values.map((value, index) => (
            <div
              class="bg-white rounded-xl p-8 transition-all hover:-translate-y-2 hover:shadow-xl border border-gray-200"
              data-reveal
              style={`animation-delay: ${index * 0.1}s`}
            >
              <div class="w-14 h-14 rounded-xl bg-accent/10 flex items-center justify-center mb-6">
                <svg
                  class="w-7 h-7 text-accent"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  set:html={value.icon}
                />
              </div>
              <h3 class="font-display text-[1.25rem] font-bold text-black mb-3">{value.title}</h3>
              <p class="text-gray-600 leading-relaxed">{value.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Fun Facts Section -->
  <section class="bg-accent-pale px-4 sm:px-6 lg:px-8 py-24 lg:py-32 relative overflow-hidden">
    <div class="max-w-[1400px] mx-auto">
      <div class="text-center mb-16" data-reveal>
        <SectionHeader
          label="Ciekawostki"
          title="Nie samym <span class='text-accent'>SEO</span> człowiek żyje"
          centered
        />
        <p class="text-[1.125rem] text-gray-600 mt-6 max-w-[600px] mx-auto">
          Bo czasem trzeba się też uśmiechnąć. Oto kilka faktów z życia naszego biura.
        </p>
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">
        {
          funFacts.map((fact, index) => (
            <div
              class="bg-white rounded-xl p-8 text-center transition-all hover:-translate-y-2 hover:shadow-xl border border-gray-200"
              data-reveal
              style={`animation-delay: ${index * 0.1}s`}
            >
              <div class="text-4xl mb-4">{fact.icon}</div>
              <div class="font-mono text-[2.5rem] font-bold text-accent mb-2">{fact.number}</div>
              <div class="text-gray-600 text-[0.9rem]">{fact.label}</div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Why Choose Us Section -->
  <section class="bg-white px-4 sm:px-6 lg:px-8 py-24 lg:py-32">
    <div class="max-w-[1400px] mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div data-reveal>
          <div
            class="font-mono text-[0.75rem] uppercase tracking-wider text-accent mb-6 font-semibold"
          >
            Dlaczego my?
          </div>
          <h2
            class="font-display text-[clamp(2rem,5vw,3.5rem)] font-black leading-[1.1] tracking-[-0.02em] mb-8 text-black"
          >
            Jeśli szukasz<br />
            <span class="text-accent">partnera</span>, nie dostawcy
          </h2>
          <p class="text-[1.125rem] leading-[1.8] text-gray-600 mb-10 max-w-[600px]">
            Nie działamy według szablonów. Nie oferujemy „pakietów SEO". Zamiast tego budujemy
            indywidualne strategie dopasowane do Twojego biznesu.
          </p>

          <ul class="space-y-4">
            <li class="flex items-start gap-3">
              <div
                class="flex-shrink-0 w-6 h-6 rounded-full bg-accent/10 flex items-center justify-center mt-1"
              >
                <svg
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="3"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="text-accent"
                >
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              </div>
              <span class="text-[1rem] lg:text-[1.125rem] text-gray-700 leading-relaxed">
                <strong>Dedykowany zespół</strong> - masz bezpośredni kontakt ze specjalistami, nie z
                account managerem
              </span>
            </li>
            <li class="flex items-start gap-3">
              <div
                class="flex-shrink-0 w-6 h-6 rounded-full bg-accent/10 flex items-center justify-center mt-1"
              >
                <svg
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="3"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="text-accent"
                >
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              </div>
              <span class="text-[1rem] lg:text-[1.125rem] text-gray-700 leading-relaxed">
                <strong>Transparentność</strong> - pełny wgląd w działania, regularne raporty, brak ukrytych
                kosztów
              </span>
            </li>
            <li class="flex items-start gap-3">
              <div
                class="flex-shrink-0 w-6 h-6 rounded-full bg-accent/10 flex items-center justify-center mt-1"
              >
                <svg
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="3"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="text-accent"
                >
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              </div>
              <span class="text-[1rem] lg:text-[1.125rem] text-gray-700 leading-relaxed">
                <strong>Focus na ROI</strong> - mierzymy sukces przychodami, nie tylko pozycjami
              </span>
            </li>
            <li class="flex items-start gap-3">
              <div
                class="flex-shrink-0 w-6 h-6 rounded-full bg-accent/10 flex items-center justify-center mt-1"
              >
                <svg
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="3"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="text-accent"
                >
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              </div>
              <span class="text-[1rem] lg:text-[1.125rem] text-gray-700 leading-relaxed">
                <strong>Technologia + strategia</strong> - łączymy wiedzę techniczną z biznesowym podejściem
              </span>
            </li>
          </ul>
        </div>

        <!-- Right side with quote -->
        <div class="relative" data-reveal>
          <div class="bg-gray-100 rounded-2xl p-10 lg:p-12 relative">
            <svg
              class="absolute top-6 left-6 w-12 h-12 text-accent/20"
              fill="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"
              ></path>
            </svg>
            <blockquote class="relative z-10">
              <p
                class="font-display text-[1.5rem] lg:text-[1.75rem] font-bold text-black leading-[1.4] mb-6"
              >
                Współpraca z TALEM to jak mieć własny dział SEO, ale lepszy. Wiedzą więcej o naszym
                sklepie niż my sami.
              </p>
              <footer>
                <cite class="not-italic">
                  <span class="block font-bold text-black">Paweł Zieliński</span>
                  <span class="text-gray-600 text-[0.9rem]">CEO, sklep z elektroniką</span>
                </cite>
              </footer>
            </blockquote>
          </div>
        </div>
      </div>
    </div>
  </section>

  <AboutUsContact />
  <Footer />
</BaseLayout>
