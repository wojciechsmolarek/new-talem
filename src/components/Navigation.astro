---
// Dane nawigacji - łatwe zarządzanie w jednym miejscu
const services = [
  {
    href: '/techniczne-seo',
    title: 'Techniczne SEO',
    desc: 'Dla e-commerce i serwisów internetowych',
    icon: '<rect x="4" y="4" width="16" height="16" rx="2" ry="2" /><rect x="9" y="9" width="6" height="6" /><line x1="9" y1="1" x2="9" y2="4" /><line x1="15" y1="1" x2="15" y2="4" /><line x1="9" y1="20" x2="9" y2="23" /><line x1="15" y1="20" x2="15" y2="23" /><line x1="20" y1="9" x2="23" y2="9" /><line x1="20" y1="15" x2="23" y2="15" /><line x1="1" y1="9" x2="4" y2="9" /><line x1="1" y1="15" x2="4" y2="15" />',
  },
  {
    href: '/content-seo',
    title: 'Content SEO',
    desc: 'Tworzenie wartościowych treści i automatyzacja procesów contentowych',
    icon: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="16" y1="13" x2="8" y2="13" /><line x1="16" y1="17" x2="8" y2="17" /><line x1="10" y1="9" x2="8" y2="9" />',
  },
  {
    href: '/migracje-sklepow',
    title: 'Migracje sklepów',
    desc: 'Bezpieczne przenoszenie sklepów, bez spadków ruchu i sprzedaży',
    icon: '<path d="m16 3 4 4-4 4" /><path d="M20 7H4" /><path d="m8 21-4-4 4-4" /><path d="M4 17h16" />',
  },
  {
    href: '/monitoring-wydajnosci',
    title: 'Monitoring wydajności',
    desc: 'Dla sklepów, platform e-commerce i serwisów WWW',
    icon: '<path d="M12 20a8 8 0 0 0 8-8V4h-8" /><path d="M12 20a8 8 0 0 1-8-8V4h8" /><path d="M10 10l2 2 4-4" />',
  },
  {
    href: '/link-building',
    title: 'Link Building',
    desc: 'Budowanie wartościowych linków i zwiększanie autorytetu domeny',
    icon: '<path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" /><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" />',
  },
  {
    href: '/analityka-i-automatyzacja',
    title: 'Analityka i automatyzacja',
    desc: 'Modelowanie danych i automatyzacje wspierane przez AI',
    icon: '<line x1="12" y1="20" x2="12" y2="10" /><line x1="18" y1="20" x2="18" y2="4" /><line x1="6" y1="20" x2="6" y2="16" />',
  },
];
---

<nav
  class="fixed top-0 left-0 w-full z-[1000] px-4 sm:px-6 lg:px-8 bg-white/95 backdrop-blur-[10px] border-b border-gray-200"
>
  <div class="max-w-[1400px] mx-auto py-4 flex justify-between items-center">
    <a href="/" class="flex items-center gap-3 group">
      <img
        src="/images/logo-talem.svg"
        alt="Talem Technologies Sp. z o. o."
        class="h-10 w-auto transition-transform group-hover:scale-105"
      />
    </a>

    <div class="hidden min-[885px]:flex gap-8 items-center">
      <a href="/o-nas" class="nav-link-hover">O nas</a>

      <div class="relative group" data-dropdown>
        <button class="nav-link-hover flex items-center gap-1.5" aria-expanded="false">
          Usługi
          <svg
            class="w-3.5 h-3.5 transition-transform group-hover:rotate-180"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 12 12"
            ><path
              d="M3 4.5L6 7.5L9 4.5"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"></path></svg
          >
        </button>

        <div
          class="absolute top-full left-1/2 -translate-x-1/2 pt-3 opacity-0 invisible group-hover:opacity-100 group-hover:visible group-hover:translate-y-0 translate-y-2 transition-all duration-200 z-50"
        >
          <div class="bg-white rounded-xl border border-gray-200 shadow-2xl p-2 w-[560px]">
            <a
              href="/seo-dla-e-commerce"
              class="block px-4 py-3 mb-1 hover:bg-gray-50 rounded-lg group/head"
            >
              <span
                class="block font-mono text-[0.6rem] uppercase tracking-widest text-accent font-bold"
                >Zaawansowane usługi</span
              >
              <span class="block text-lg text-black group-hover/head:text-accent"
                >SEO dla E-commerce</span
              >
            </a>
            <div class="h-px bg-gray-100 mx-3 mb-1"></div>
            <div class="grid grid-cols-2 gap-1">
              {
                services.map((service) => (
                  <a
                    href={service.href}
                    class="flex items-start gap-3 px-4 py-3 rounded-lg hover:bg-gray-50 transition-colors group/item"
                  >
                    <div class="w-10 h-10 shrink-0 rounded bg-accent/5 flex items-center justify-center text-accent group-hover/item:bg-accent group-hover/item:text-white transition-colors">
                      <svg
                        class="w-5 h-5"
                        aria-hidden="true"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        set:html={service.icon}
                      />
                    </div>
                    <div>
                      <span class="block text-sm font-bold text-black group-hover/item:text-accent">
                        {service.title}
                      </span>
                      <span class="block text-[0.75rem] text-gray-500 leading-snug">
                        {service.desc}
                      </span>
                    </div>
                  </a>
                ))
              }
            </div>
          </div>
        </div>
      </div>

      <a href="/kontakt" class="nav-link-hover">Kontakt</a>

      <a
        href="https://seo-net.pl/users/login"
        rel="noopener noreferrer"
        target="_blank"
        class="nav-link-hover">👤 Panel klienta</a
      >
      <a
        href="#kontakt"
        class="px-6 py-2.5 bg-accent text-white rounded-[7px] font-bold transition-all hover:bg-black hover:scale-105 active:scale-95 shadow-md"
      >
        Bezpłatna konsultacja
      </a>
    </div>

    <button
      data-mobile-menu-toggle
      class="max-[885px]:block hidden p-2 text-black"
      aria-label="Menu"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"
        ><path d="M4 6h16M4 12h16M4 18h16" stroke-width="2"></path></svg
      >
    </button>
  </div>
</nav>

<div
  data-mobile-overlay
  class="fixed inset-0 bg-black/50 backdrop-blur-sm z-[1001] hidden opacity-0 transition-opacity duration-300"
>
</div>
<div
  data-mobile-panel
  class="fixed top-0 right-0 bottom-0 w-[80%] max-w-sm bg-white z-[1002] translate-x-full transition-transform duration-300 p-6 flex flex-col"
>
  <div class="flex justify-between items-center mb-8">
    <span class="text-xl font-bold">Menu</span>
    <button data-mobile-menu-close class="p-2">✕</button>
  </div>
  <nav class="flex flex-col gap-4">
    <a href="#proces" class="text-lg font-medium border-b border-gray-100 pb-2">O nas</a>

    <div class="py-2">
      <span class="text-accent font-bold text-sm uppercase">Usługi</span>
      <div class="grid grid-cols-1 gap-3 mt-3 pl-2">
        {
          services.map((s) => (
            <a href={s.href} class="flex items-center gap-3 text-base text-gray-700 py-1">
              <div class="w-8 h-8 shrink-0 rounded bg-accent/5 flex items-center justify-center text-accent">
                <svg
                  class="w-4 h-4"
                  aria-hidden="true"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  set:html={s.icon}
                />
              </div>
              {s.title}
            </a>
          ))
        }
      </div>
    </div>

    <a href="/kontakt" class="text-lg font-medium border-b border-gray-100 pb-2">Kontakt</a>

    <a
      href="https://seo-net.pl/users/login"
      rel="noopener noreferrer"
      target="_blank"
      class="text-lg font-medium border-b border-gray-100 pb-2">👤 Panel klienta</a
    >

    <a
      href="#kontakt"
      class="mt-4 px-6 py-3 bg-accent text-white rounded-[7px] text-center font-bold"
      >Bezpłatna konsultacja</a
    >
  </nav>
</div>

<style>
  @reference "../styles/global.css";

  .nav-link-hover {
    @apply relative text-zinc-950 font-medium text-[0.95rem] transition-colors hover:text-accent;
  }
  .nav-link-hover::after {
    content: '';
    @apply absolute -bottom-1 left-0 w-0 h-0.5 bg-accent transition-all duration-300;
  }
  .nav-link-hover:hover::after {
    @apply w-full;
  }
</style>

<script>
  // 1. Mobile Menu Logic
  const btnOpen = document.querySelector('[data-mobile-menu-toggle]');
  const btnClose = document.querySelector('[data-mobile-menu-close]');
  const overlay = document.querySelector('[data-mobile-overlay]');
  const panel = document.querySelector('[data-mobile-panel]');

  function toggleMenu(isOpen: boolean) {
    if (!overlay || !panel) return;
    overlay.classList.toggle('hidden', !isOpen);
    setTimeout(() => overlay?.classList.toggle('opacity-100', isOpen), 10);
    panel.classList.toggle('translate-x-full', !isOpen);
    document.body.style.overflow = isOpen ? 'hidden' : '';
  }

  btnOpen?.addEventListener('click', () => toggleMenu(true));
  btnClose?.addEventListener('click', () => toggleMenu(false));
  overlay?.addEventListener('click', () => toggleMenu(false));
</script>
