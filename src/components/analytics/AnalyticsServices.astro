---
import SectionHeader from '../ui/SectionHeader.astro';

const services = [
  {
    number: '01',
    title: 'Analityka SEO dla e-commerce i sklepów internetowych',
    description:
      'Analizujemy dane w kontekście biznesowym. Badamy, jaki wpływ na sprzedaż mają widoczność, ruch, zachowania użytkowników i ścieżki konwersji. Identyfikujemy obszary serwisu, które generują realną wartość, oraz te z potencjałem wzrostu, które wymagają optymalizacji.',
  },
  {
    number: '02',
    title: 'Konfiguracja, weryfikacja i audyty GA4 oraz GSC',
    description:
      'Zapewniamy poprawną konfigurację narzędzi analitycznych i weryfikujemy poprawność danych, tak aby decyzje marketingowe były oparte na rzetelnych informacjach. Sprawdzamy zdarzenia, konwersje, atrybucję i integrację danych.',
  },
  {
    number: '03',
    title: 'Segmentacja i modelowanie danych',
    description:
      'Dzielimy dane według produktów, kategorii, typów stron, intencji wyszukiwania i etapów lejka zakupowego. Pozwala to precyzyjnie określić, które obszary przynoszą największy zwrot z działań SEO, a które wymagają poprawy.',
  },
  {
    number: '04',
    title: 'Analiza luk w treściach i konkurencji',
    description:
      'Identyfikujemy brakujące treści, frazy i tematy, które konkurencja wykorzystuje do generowania ruchu. Dzięki temu obrana strategia działań opiera się na realnych szansach wzrostu widoczności i sprzedaży.',
  },
  {
    number: '05',
    title: 'Analiza potencjału wzrostu i identyfikacja „quick wins"',
    description:
      'Znajdujemy obszary, w których możliwy jest najszybszy wzrost widoczności fraz kluczowych i ruchu. Wskazujemy wymagające optymalizacji podstrony, treści o wysokim, lecz niewykorzystanym potencjale, a także problemy techniczne ograniczające efekty w wyszukiwarkach.',
  },
  {
    number: '06',
    title: 'Prognozowanie potencjału wzrostu widoczności i sprzedaży',
    description:
      'Na podstawie danych historycznych, trendów i analiz konkurencji przewidujemy możliwe scenariusze wzrostu ruchu organicznego i przychodów. Umożliwia to planowanie działań w sposób kontrolowany i opłacalny biznesowo.',
  },
  {
    number: '07',
    title: 'Automatyzacja analiz i raportów (AI / workflow / integracje)',
    description:
      'Wdrażamy automatyzacje, które skracają czasochłonne procesy analityczne: monitorowanie zmian w widoczności i ruchu, generowanie raportów dla zespołów marketingu i zarządu, wykrywanie anomalii w wynikach SEO.',
  },
  {
    number: '08',
    title: 'Dashboardy i raporty decyzyjne',
    description:
      'Tworzymy czytelne panele analityczne prezentujące najważniejsze wskaźniki efektywności: widoczność, ruch organiczny, konwersje, przychody i trendy. Raporty są zrozumiałe dla właścicieli sklepów, a jednocześnie precyzyjne dla zespołów SEO i marketingu.',
  },
  {
    number: '09',
    title: 'Systemy wczesnego wykrywania problemów',
    description:
      'Wdrażamy mechanizmy monitorujące nagłe spadki widoczności, błędy indeksacji i anomalie w danych. W ten sposób zapewniamy szybką reakcję na problemy techniczne i utrzymanie stabilnych wzrostów widoczności i sprzedaży.',
  },
];
---

<section id="uslugi-analytics" class="bg-gray-100 px-4 sm:px-6 lg:px-8 py-24 lg:py-32">
  <div class="max-w-[1400px] mx-auto">
    <!-- Header -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 mb-20">
      <SectionHeader label="ZAKRES DZIAŁAŃ" title="Co robimy w ramach<br />analityki SEO i automatyzacji" />
      <div class="flex items-end">
        <p class="text-[0.95rem] lg:text-[1.05rem] leading-[1.8] text-gray-600 max-w-[520px]">
          Rozwój widoczności staje się procesem mierzalnym, kontrolowanym i skalowalnym — opartym
          na danych, a nie domysłach.
        </p>
      </div>
    </div>

    <!-- Service cards grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        services.map((service) => (
          <div class="bg-white border-2 border-gray-200 rounded-2xl p-8 lg:p-10 relative transition-all duration-300 hover:border-accent hover:-translate-y-2 hover:shadow-2xl group">
            <div class="flex items-center gap-4 mb-6">
              <div class="w-12 h-12 rounded-xl bg-accent/5 flex items-center justify-center group-hover:bg-accent group-hover:text-white transition-colors">
                <svg
                  class="w-5 h-5 text-accent group-hover:text-white transition-colors"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  stroke-width="1.5"
                >
                  <line x1="12" y1="20" x2="12" y2="10" stroke-linecap="round" stroke-linejoin="round" />
                  <line x1="18" y1="20" x2="18" y2="4" stroke-linecap="round" stroke-linejoin="round" />
                  <line x1="6" y1="20" x2="6" y2="16" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </div>
              <span class="font-mono text-[0.85rem] font-bold text-gray-400">{service.number}</span>
            </div>

            <h3 class="font-display text-[1.2rem] lg:text-[1.35rem] font-bold mb-4 leading-[1.3]">
              {service.title}
            </h3>

            <p class="text-gray-600 leading-[1.7] text-[0.92rem]">{service.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
