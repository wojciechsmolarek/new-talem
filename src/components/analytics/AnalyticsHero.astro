<section
  class="relative min-h-[100vh] flex items-center px-4 sm:px-6 lg:px-8 pt-32 pb-16 overflow-hidden bg-white"
>
  <div class="max-w-[1400px] mx-auto w-full relative z-[2]">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Left column -->
      <div>
        <span
          class="font-mono text-[0.75rem] font-semibold tracking-[0.1em] uppercase text-accent mb-6 block"
        >
          USŁUGA
        </span>
        <h1
          class="font-display text-[clamp(2.5rem,7vw,4.5rem)] font-black leading-[1.1] tracking-[-0.03em] mb-8"
        >
          Analityka <span class="italic">i</span><br />
          automatyzacja
        </h1>
        <p class="text-[1rem] lg:text-[1.1rem] leading-[1.8] text-gray-600 mb-6 max-w-[460px]">
          Dane są fundamentem skutecznych działań SEO i e-commerce. Wdrażamy zaawansowane rozwiązania
          analityczne i automatyzacje, które pozwalają podejmować trafne decyzje biznesowe.
        </p>
      </div>

      <!-- Right column -->
      <div class="flex flex-col justify-center">
        <p class="text-[1rem] lg:text-[1.1rem] leading-[1.8] text-gray-600 mb-6 max-w-[460px]">
          Łączymy <strong>modelowanie danych, inteligentną automatyzację i rozwiązania AI</strong>,
          aby dostarczyć Ci pełny obraz wydajności Twojego sklepu. Tworzymy dashboardy, raporty i
          alerty, które pomagają reagować na zmiany w czasie rzeczywistym.
        </p>
        <p class="text-[1rem] lg:text-[1.1rem] leading-[1.8] text-gray-600 mb-6 max-w-[460px]">
          Nasze rozwiązania <strong>oszczędzają czas i eliminują błędy ludzkie</strong> w powtarzalnych
          procesach, pozwalając zespołowi skupić się na strategicznych działaniach.
        </p>
        <div class="flex gap-4 flex-wrap">
          <a
            href="#uslugi-analytics"
            class="inline-flex items-center justify-center px-7 py-4 rounded-lg font-semibold transition text-[0.95rem] bg-transparent text-black border-2 border-gray-300 hover:border-black hover:bg-black hover:text-white"
            >Zobacz zakres usług</a
          >
        </div>
      </div>
    </div>
  </div>

  <!-- Decorative elements -->
  <div
    class="hidden lg:block absolute top-[10%] right-[-5%] w-[500px] h-[500px] rounded-full bg-accent-pale opacity-60 z-[1]"
  >
  </div>
</section>
