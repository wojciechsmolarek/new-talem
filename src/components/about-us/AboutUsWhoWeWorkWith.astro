---
const traits = [
  {
    icon: '<path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />',
    title: 'Myślą o SEO długoterminowo',
    desc: 'Rozumieją, że organiczny wzrost widoczności to proces wymagający czasu i konsekwencji.',
  },
  {
    icon: '<path d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />',
    title: 'Gotowe rozwijać sklep technicznie i contentowo',
    desc: 'Otwarte na wdrożenia techniczne i tworzenie wartościowych treści, które budują pozycję.',
  },
  {
    icon: '<path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />',
    title: 'Traktują agencję jako partnera strategicznego',
    desc: 'Doceniają bliską współpracę i traktują nas jak przedłużenie własnego zespołu.',
  },
];
---

<section class="bg-gray-100 px-4 sm:px-6 lg:px-8 py-24 lg:py-32">
  <div class="max-w-[1400px] mx-auto">
    <div class="text-center mb-16" data-reveal>
      <div
        class="font-mono text-[0.75rem] uppercase tracking-wider text-accent mb-6 font-semibold inline-block"
      >
        Idealna współpraca
      </div>
      <h2
        class="font-display text-[clamp(2rem,5vw,3.5rem)] font-black leading-[1.1] tracking-[-0.02em] text-black"
      >
        Z kim najlepiej<br />
        <span class="text-accent">się współpracuje</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
      {
        traits.map((trait, index) => (
          <div
            class="bg-white rounded-xl p-8 border border-gray-200 hover:-translate-y-2 hover:shadow-xl transition-all"
            data-reveal
            style={`animation-delay: ${index * 0.1}s`}
          >
            <div class="w-14 h-14 rounded-xl bg-accent/10 flex items-center justify-center mb-6">
              <svg
                class="w-7 h-7 text-accent"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                set:html={trait.icon}
              />
            </div>
            <h3 class="font-display text-[1.125rem] font-bold text-black mb-3">{trait.title}</h3>
            <p class="text-gray-600 leading-relaxed">{trait.desc}</p>
          </div>
        ))
      }
    </div>

    <div class="text-center" data-reveal>
      <p class="text-[1.125rem] leading-[1.8] text-gray-600 max-w-[640px] mx-auto">
        Taki model współpracy pozwala skupić się na tym, co naprawdę ma znaczenie — <strong
          class="text-black">trwałym wzroście widoczności i sprzedaży</strong
        >.
      </p>
    </div>
  </div>
</section>
