---
---

<section class="bg-black text-white px-4 sm:px-6 lg:px-8 py-24 lg:py-32 relative overflow-hidden">
  <div class="max-w-[1400px] mx-auto text-center relative z-[2]" data-reveal>
    <div
      class="font-mono text-[0.75rem] uppercase tracking-wider text-accent mb-6 font-semibold"
    >
      Zacznijmy współpracę
    </div>
    <h2
      class="font-display text-[clamp(2rem,5vw,3.5rem)] font-black leading-[1.1] tracking-[-0.02em] mb-8 text-white"
    >
      Jeśli szukasz zespołu,<br />
      który rozumie <span class="text-accent">e-commerce</span>
    </h2>
    <p class="text-[1.125rem] leading-[1.8] text-gray-300 max-w-[640px] mx-auto mb-12">
      Jeśli szukasz zespołu, który rozumie handel internetowy i pracuje blisko z klientem — jesteś
      we właściwym miejscu. Porozmawiajmy o tym, jak możemy rozwinąć widoczność Twojego sklepu w
      Google.
    </p>
    <div class="flex gap-4 flex-wrap justify-center">
      <a
        href="#kontakt"
        class="inline-flex items-center justify-center min-w-[220px] px-8 py-4 rounded-lg font-semibold transition text-base bg-accent text-white hover:bg-accent/90"
      >
        Porozmawiajmy
      </a>
      <a
        href="/seo-dla-e-commerce"
        class="inline-flex items-center justify-center min-w-[220px] px-8 py-4 rounded-lg font-semibold transition text-base bg-transparent text-white border-2 border-white/30 hover:border-white hover:bg-white hover:text-black"
      >
        Sprawdź ofertę
      </a>
    </div>
  </div>

  <!-- Background grid -->
  <div class="absolute inset-0 z-[1] opacity-20">
    <div
      class="w-full h-full bg-[linear-gradient(to_right,rgba(255,255,255,0.1)_1px,transparent_1px),linear-gradient(to_bottom,rgba(255,255,255,0.1)_1px,transparent_1px)] bg-[size:40px_40px] [mask-image:radial-gradient(ellipse_at_center,black_20%,transparent_80%)]"
    >
    </div>
  </div>
</section>
