---
const tools = [
  {
    icon: '<path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />',
    label: 'analitykę danych',
  },
  {
    icon: '<path d="M13 10V3L4 14h7v7l9-11h-7z" />',
    label: 'automatyzację procesów',
  },
  {
    icon: '<path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />',
    label: 'narzędzia oparte na AI',
  },
];
---

<section class="bg-white px-4 sm:px-6 lg:px-8 py-24 lg:py-32">
  <div class="max-w-[1400px] mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <div data-reveal>
        <div
          class="font-mono text-[0.75rem] uppercase tracking-wider text-accent mb-6 font-semibold"
        >
          Doświadczenie
        </div>
        <h2
          class="font-display text-[clamp(2rem,5vw,3.5rem)] font-black leading-[1.1] tracking-[-0.02em] mb-8 text-black"
        >
          W branży SEO<br />
          <span class="text-accent">od 2006 roku</span>
        </h2>
        <p class="text-[1.125rem] leading-[1.8] text-gray-600 mb-6">
          Jesteśmy najdłużej działającą agencją SEO w Bydgoszczy. Od 2006 roku realizujemy projekty
          dla sklepów internetowych i serwisów e-commerce.
        </p>
        <p class="text-[1.125rem] leading-[1.8] text-gray-600 mb-10">
          Ten czas to setki projektów, zmiany algorytmów Google, rozwój technologii i ewolucja
          handlu internetowego. Doświadczenie zdobywane przez lata łączymy z nowoczesnym podejściem
          do marketingu cyfrowego.
        </p>
        <div class="space-y-4">
          <p class="font-semibold text-black mb-4">W naszej pracy wykorzystujemy:</p>
          <ul class="space-y-3">
            {
              tools.map((tool) => (
                <li class="flex items-start gap-3">
                  <div class="flex-shrink-0 w-6 h-6 rounded-full bg-accent/10 flex items-center justify-center mt-1">
                    <svg
                      width="14"
                      height="14"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="3"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="text-accent"
                    >
                      <polyline points="20 6 9 17 4 12" />
                    </svg>
                  </div>
                  <span class="text-[1rem] lg:text-[1.125rem] text-gray-700 leading-relaxed">
                    {tool.label}
                  </span>
                </li>
              ))
            }
          </ul>
        </div>
        <p class="text-[1.125rem] leading-[1.8] text-gray-600 mt-8">
          Dzięki temu możemy łączyć wieloletnie doświadczenie z nowoczesnymi metodami optymalizacji.
        </p>
      </div>

      <!-- Timeline visualization -->
      <div class="relative" data-reveal>
        <div class="bg-gray-100 rounded-2xl p-10 relative">
          <div class="space-y-8">
            <!-- Timeline item 1 -->
            <div class="flex gap-4 items-start">
              <div
                class="flex-shrink-0 w-12 h-12 rounded-full bg-accent flex items-center justify-center text-white font-bold text-sm"
              >
                2006
              </div>
              <div>
                <h4 class="font-bold text-black mb-2">Początek działalności</h4>
                <p class="text-gray-600 text-[0.95rem] leading-relaxed">
                  Start agencji w Bydgoszczy
                </p>
              </div>
            </div>

            <!-- Timeline item 2 -->
            <div class="flex gap-4 items-start">
              <div
                class="flex-shrink-0 w-12 h-12 rounded-full bg-accent/80 flex items-center justify-center text-white font-bold text-sm"
              >
                250+
              </div>
              <div>
                <h4 class="font-bold text-black mb-2">Zrealizowanych projektów</h4>
                <p class="text-gray-600 text-[0.95rem] leading-relaxed">
                  Setki wdrożeń dla e-commerce
                </p>
              </div>
            </div>

            <!-- Timeline item 3 -->
            <div class="flex gap-4 items-start">
              <div
                class="flex-shrink-0 w-12 h-12 rounded-full bg-accent/60 flex items-center justify-center text-white font-bold text-sm"
              >
                2024
              </div>
              <div>
                <h4 class="font-bold text-black mb-2">AI i automatyzacja</h4>
                <p class="text-gray-600 text-[0.95rem] leading-relaxed">
                  Integracja narzędzi AI z doświadczeniem
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
