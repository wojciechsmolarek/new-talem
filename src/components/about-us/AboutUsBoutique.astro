---
const reasons = [
  'szybciej reagować na zmiany i nowe możliwości',
  'planować działania w perspektywie długoterminowej',
  'dokładnie poznawać specyfikę branży klienta',
  'realnie wpływać na rozwój sklepu, a nie tylko raportować pozycje',
];
---

<section class="bg-black text-white px-4 sm:px-6 lg:px-8 py-24 lg:py-32 relative overflow-hidden">
  <div class="max-w-[1400px] mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <div data-reveal>
        <div
          class="font-mono text-[0.75rem] uppercase tracking-wider text-accent mb-6 font-semibold"
        >
          Nasze podejście
        </div>
        <h2
          class="font-display text-[clamp(2rem,5vw,3.5rem)] font-black leading-[1.1] tracking-[-0.02em] mb-8 text-white"
        >
          Dlaczego działamy jako<br />
          <span class="text-accent">butikowa agencja SEO</span>
        </h2>
        <p class="text-[1.125rem] leading-[1.8] text-gray-300 mb-8">
          Ograniczona i dopasowana liczba projektów pozwala nam:
        </p>
        <ul class="space-y-4 mb-10">
          {
            reasons.map((reason) => (
              <li class="flex items-start gap-3">
                <div class="flex-shrink-0 w-6 h-6 rounded-full bg-accent/20 flex items-center justify-center mt-1">
                  <svg
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="3"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="text-accent"
                  >
                    <polyline points="20 6 9 17 4 12" />
                  </svg>
                </div>
                <span class="text-[1rem] lg:text-[1.125rem] text-gray-300 leading-relaxed">
                  {reason}
                </span>
              </li>
            ))
          }
        </ul>
        <p class="text-[1.125rem] leading-[1.8] text-gray-400 border-l-2 border-accent pl-6 italic">
          Nie działamy w modelu „taśmowej produkcji SEO". Każdy projekt traktujemy indywidualnie.
        </p>
      </div>

      <!-- Decorative element -->
      <div class="relative h-[400px] hidden lg:block" data-reveal>
        <div
          class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[300px] h-[300px] rounded-full border-2 border-accent/30"
        >
        </div>
        <div
          class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 translate-x-[30px] translate-y-[-20px] w-[200px] h-[200px] rounded-full bg-accent shadow-2xl"
        >
        </div>
        <div
          class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 translate-x-[-80px] translate-y-[60px] w-[120px] h-[120px] rounded-full border-2 border-accent/20"
        >
        </div>
      </div>
    </div>
  </div>
</section>
