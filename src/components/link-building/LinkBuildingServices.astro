---
import SectionHeader from '../ui/SectionHeader.astro';

const services = [
  {
    number: '01',
    title: 'Audyt profilu linkowego',
    description:
      'Analizujemy obecny profil linków Twojej domeny, identyfikujemy linki toksyczne i szkodliwe oraz oceniamy jakość i tematyczność istniejących odnośników. Na tej podstawie tworzymy strategię link buildingu.',
  },
  {
    number: '02',
    title: 'Analiza konkurencji i identyfikacja możliwości',
    description:
      'Badamy profile linkowe konkurentów, aby zidentyfikować źródła linków, które sprawdzają się w Twojej branży. Wykorzystujemy te dane do budowy przewagi konkurencyjnej.',
  },
  {
    number: '03',
    title: 'Outreach i pozyskiwanie linków',
    description:
      'Prowadzimy profesjonalne kampanie outreachowe, nawiązując kontakt z właścicielami wartościowych serwisów branżowych, blogerami i mediami w celu pozyskania naturalnych linków.',
  },
  {
    number: '04',
    title: 'Content marketing linkowy',
    description:
      'Tworzymy wartościowe treści (artykuły eksperckie, infografiki, raporty branżowe), które naturalnie przyciągają linki i wzmacniają autorytet Twojej marki jako eksperta w branży.',
  },
  {
    number: '05',
    title: 'Digital PR i publikacje w mediach',
    description:
      'Budujemy widoczność marki poprzez publikacje w portalach branżowych, mediach i serwisach informacyjnych. Pozyskujemy linki z autorytatywnych źródeł, które realnie wpływają na pozycje.',
  },
  {
    number: '06',
    title: 'Monitoring i raportowanie',
    description:
      'Regularnie monitorujemy przyrost linków, analizujemy ich wpływ na widoczność i pozycje oraz raportujemy postępy. Dbamy o bezpieczeństwo profilu linkowego i reagujemy na potencjalne zagrożenia.',
  },
];
---

<section id="uslugi-linkbuilding" class="bg-gray-100 px-4 sm:px-6 lg:px-8 py-24 lg:py-32">
  <div class="max-w-[1400px] mx-auto">
    <!-- Header -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 mb-20">
      <SectionHeader label="ZAKRES DZIAŁAŃ" title="Co robimy w ramach<br />Link Buildingu" />
      <div class="flex items-end">
        <p class="text-[0.95rem] lg:text-[1.05rem] leading-[1.8] text-gray-600 max-w-[520px]">
          Budujemy profil linków, który wzmacnia autorytet domeny, zwiększa zaufanie w oczach Google
          i przekłada się na wyższe pozycje oraz większy ruch organiczny.
        </p>
      </div>
    </div>

    <!-- Service cards grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        services.map((service) => (
          <div class="bg-white border-2 border-gray-200 rounded-2xl p-8 lg:p-10 relative transition-all duration-300 hover:border-accent hover:-translate-y-2 hover:shadow-2xl group">
            <div class="flex items-center gap-4 mb-6">
              <div class="w-12 h-12 rounded-xl bg-accent/5 flex items-center justify-center group-hover:bg-accent group-hover:text-white transition-colors">
                <svg
                  class="w-5 h-5 text-accent group-hover:text-white transition-colors"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  stroke-width="1.5"
                >
                  <path
                    d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                  <path
                    d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </div>
              <span class="font-mono text-[0.85rem] font-bold text-gray-400">{service.number}</span>
            </div>

            <h3 class="font-display text-[1.2rem] lg:text-[1.35rem] font-bold mb-4 leading-[1.3]">
              {service.title}
            </h3>

            <p class="text-gray-600 leading-[1.7] text-[0.92rem]">{service.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
