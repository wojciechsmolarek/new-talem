---
import SectionHeader from '../ui/SectionHeader.astro';

const services = [
  {
    number: '01',
    title: 'Audyt i analiza profilu linków własnych oraz konkurencji',
    description:
      'Sprawdzamy jakość i strukturę linków prowadzących do Twojej witryny oraz analizujemy profile konkurencji. Dzięki temu wiemy, które linki wzmacniają autorytet, a które mogą go osłabiać. Wskazujemy luki, które dają okazję do szybkiego wzrostu widoczności.',
  },
  {
    number: '02',
    title: 'Opracowanie strategii link buildingu',
    description:
      'Budujemy spersonalizowaną strategię pozyskiwania linków, dopasowaną zarówno do celów SEO, jak i biznesowych sklepu. W strategii uwzględniamy m.in.: profil linków konkurencji, wartościowe źródła, linki z dokumentów udostępnianych w sieci oraz powiązania tematyczne. Tworzymy harmonogram działań, tak aby linki były dystrybuowane w naturalnym rytmie, bezpieczne i przynosiły trwały efekt w wynikach wyszukiwania.',
  },
  {
    number: '03',
    title: 'Pozyskiwanie linków kontekstowych i treściowych',
    description:
      'Wdrażamy działania mające na celu zdobywanie linków w treściach powiązanych tematycznie z Twoją branżą. Skupiamy się na jakości, a nie ilości, aby każdy link realnie wzmacniał autorytet domeny i pozycję w wyszukiwarkach.',
  },
  {
    number: '04',
    title: 'Budowanie linków brandowych i wzmacnianie zaufania domeny',
    description:
      'Tworzymy kampanie linkowania, które wzmacniają wizerunek marki w sieci i zwiększają świadomość wśród klientów. Dodatkowo dbamy o linki naturalne, które podnoszą zaufanie domeny w oczach Google i użytkowników.',
  },
  {
    number: '05',
    title: 'Oczyszczanie i optymalizacja profilu linków',
    description:
      'Monitorujemy profil linków i ograniczamy wpływ potencjalnie szkodliwych odnośników o niskiej jakości. Dzięki temu Twój sklep unika kar od wyszukiwarek i utrzymuje stabilny wzrost widoczności.',
  },
];
---

<section id="uslugi-linkbuilding" class="bg-gray-100 px-4 sm:px-6 lg:px-8 py-24 lg:py-32">
  <div class="max-w-[1400px] mx-auto">
    <!-- Header -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 mb-20">
      <SectionHeader label="ZAKRES DZIAŁAŃ" title="Co robimy w ramach<br />Link Building i autorytetu domeny" />
      <div class="flex items-end">
        <p class="text-[0.95rem] lg:text-[1.05rem] leading-[1.8] text-gray-600 max-w-[520px]">
          Budujemy autorytet domeny poprzez wartościowe linki pozyskiwane w naturalny i bezpieczny
          sposób, które przynoszą trwały efekt w wynikach wyszukiwania.
        </p>
      </div>
    </div>

    <!-- Service cards grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        services.map((service) => (
          <div class="bg-white border-2 border-gray-200 rounded-2xl p-8 lg:p-10 relative transition-all duration-300 hover:border-accent hover:-translate-y-2 hover:shadow-2xl group">
            <div class="flex items-center gap-4 mb-6">
              <div class="w-12 h-12 rounded-xl bg-accent/5 flex items-center justify-center group-hover:bg-accent group-hover:text-white transition-colors">
                <svg
                  class="w-5 h-5 text-accent group-hover:text-white transition-colors"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  stroke-width="1.5"
                >
                  <path
                    d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                  <path
                    d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </div>
              <span class="font-mono text-[0.85rem] font-bold text-gray-400">{service.number}</span>
            </div>

            <h3 class="font-display text-[1.2rem] lg:text-[1.35rem] font-bold mb-4 leading-[1.3]">
              {service.title}
            </h3>

            <p class="text-gray-600 leading-[1.7] text-[0.92rem]">{service.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
