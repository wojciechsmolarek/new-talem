---
import SectionHeader from '../ui/SectionHeader.astro';
import ServiceCard from '../ui/ServiceCard.astro';
---

<section id="uslugi" class="bg-gray-100 px-4 sm:px-6 lg:px-8 py-24 lg:py-32">
  <div class="max-w-[1400px] mx-auto mb-16">
    <SectionHeader label="CO ROBIMY?" title="Kompleksowe rozwiązania SEO <br>dla e-commerce" />
    <p class="mt-8 text-[1.125rem] lg:text-[1.25rem] leading-[1.8] text-gray-600">
      Integrujemy wszystkie obszary SEO, aby Twój sklep rozwijał się stabilnie i przewidywalnie – od
      technicznych fundamentów serwisu, przez treści i autorytet domeny, po analitykę oraz
      automatyzację. Nasze działania są praktyczne, skuteczne i mają bezpośredni wpływ na
      widoczność, ruch oraz sprzedaż.
    </p>
  </div>

  <div class="max-w-[1400px] mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
    <ServiceCard
      number="01"
      title="Techniczne SEO"
      description="Zapewniamy zaawansowane techniczne SEO dla  sklepów internetowych i platform e-commerce wspierające indeksację i wzrost widoczności."
      features={[
        'Optymalizacja architektury SEO witryny',
        'Optymalizacja indeksacji i zarządzanie crawl budgetem',
        'Optymalizacja wydajności i parametrów Core Web Vitals',
        'Implementacja danych strukturalnych',
        'Optymalizacja pod wyniki rozszerzone',
      ]}
      link="#"
    >
      <svg
        slot="icon"
        aria-hidden="true"
        width="40"
        height="40"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <rect x="4" y="4" width="16" height="16" rx="2" ry="2"></rect>
        <rect x="9" y="9" width="6" height="6"></rect>
        <line x1="9" y1="1" x2="9" y2="4"></line>
        <line x1="15" y1="1" x2="15" y2="4"></line>
        <line x1="9" y1="20" x2="9" y2="23"></line>
        <line x1="15" y1="20" x2="15" y2="23"></line>
        <line x1="20" y1="9" x2="23" y2="9"></line>
        <line x1="20" y1="15" x2="23" y2="15"></line>
        <line x1="1" y1="9" x2="4" y2="9"></line>
        <line x1="1" y1="15" x2="4" y2="15"></line>
      </svg>
    </ServiceCard>

    <ServiceCard
      number="02"
      title="Content SEO"
      description="Tworzymy wartościowe treści SEO, oparte na analizie intencji wyszukiwania i potrzeb klientów, które zwiększają widoczność i sprzedaż."
      features={[
        'Badanie i dobór fraz kluczowych',
        'Analiza intencji wyszukiwania',
        'Projektowanie strategii treści i architektury tematycznej',
        'Mapowanie fraz kluczowych do struktury serwisu',
        'Tworzenie i optymalizacja semantyczna treści',
      ]}
      link="#"
    >
      <svg
        slot="icon"
        aria-hidden="true"
        width="40"
        height="40"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
        <polyline points="14 2 14 8 20 8"></polyline>
        <line x1="16" y1="13" x2="8" y2="13"></line>
        <line x1="16" y1="17" x2="8" y2="17"></line>
        <line x1="10" y1="9" x2="8" y2="9"></line>
      </svg>
    </ServiceCard>

    <ServiceCard
      number="03"
      title="Migracje sklepów"
      description="Przeprowadzamy migracje sklepów internetowych z zachowaniem widoczności SEO, struktury ruchu i ciągłości sprzedaży."
      features={[
        'Analiza danych i planowanie strategii migracji',
        'Projektowanie architektury SEO nowego sklepu',
        'Mapowanie adresów URL i wdrażanie przekierowań 301',
        'Migracja struktury serwisu, kategorii i treści',
        'Monitoring widoczności i optymalizacja SEO po migracji',
      ]}
      link="#"
    >
      <svg
        slot="icon"
        aria-hidden="true"
        width="40"
        height="40"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="m16 3 4 4-4 4"></path>
        <path d="M20 7H4"></path>
        <path d="m8 21-4-4 4-4"></path>
        <path d="M4 17h16"></path>
      </svg>
    </ServiceCard>

    <ServiceCard
      number="04"
      title="Monitoring wydajności"
      description="Monitorujemy wydajność sklepów w oparciu o dane rzeczywistych użytkowników i identyfikujemy problemy wpływające na SEO i UX."
      features={[
        'Monitoring Core Web Vitals (CWV)',
        'Monitoring wydajności i czasu ładowania',
        'Monitoring wydajności w oparciu o dane użytkowników (RUM)',
        'Analiza wydajności na poziomie użytkownika',
        'Raportowanie i rekomendacje optymalizacyjne',
      ]}
      link="#"
    >
      <svg
        slot="icon"
        aria-hidden="true"
        width="40"
        height="40"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M12 20a8 8 0 0 0 8-8V4h-8"></path>
        <path d="M12 20a8 8 0 0 1-8-8V4h8"></path>
        <path d="M10 10l2 2 4-4"></path>
      </svg>
    </ServiceCard>

    <ServiceCard
      number="05"
      title="Link building"
      description="Budujemy autorytet sklepów dzięki mocnym linkom i sygnałom zewnętrznym, wspierając wzrost widoczności w wyszukiwarkach."
      features={[
        'Analiza profilu linków własnych i konkurencji',
        'Opracowywanie strategii link buildingu',
        'Pozyskiwanie linków kontekstowych i treściowych',
        'Budowanie profilu linkowego',
        'Oczyszczanie i optymalizacja profilu linków',
      ]}
      link="#"
    >
      <svg
        slot="icon"
        aria-hidden="true"
        width="40"
        height="40"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
        <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
      </svg>
    </ServiceCard>

    <ServiceCard
      number="06"
      title="Analityka i automatyzacja"
      description="Opieramy SEO na danych, pomagając przewidywać i skalować wzrost widoczności oraz przychodów z ruchu organicznego."
      features={[
        'Analityka SEO dla e-commerce',
        'Konfiguracja, weryfikacja i audyty GA4 oraz GSC',
        'Segmentacja i modelowanie danych SEO',
        'Prognozowanie potencjału wzrostu widoczności',
        'Automatyzacja analiz SEO oraz dashboardy i raporty decyzyjne',
      ]}
      link="#"
    >
      <svg
        slot="icon"
        aria-hidden="true"
        width="40"
        height="40"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <line x1="12" y1="20" x2="12" y2="10"></line>
        <line x1="18" y1="20" x2="18" y2="4"></line>
        <line x1="6" y1="20" x2="6" y2="16"></line>
      </svg>
    </ServiceCard>
  </div>
</section>
