---
import SectionHeader from '../ui/SectionHeader.astro';

const steps = [
  {
    number: '01',
    title: 'Poznanie potrzeb',
    desc: 'Poznajemy ofertę, profil i oczekiwania Twojej firmy. Badamy rynek i konkurencję. Określamy wspólne cele.',
  },
  {
    number: '02',
    title: 'Analiza i audyt',
    desc: 'Wykonujemy audyt SEO strony. Badamy obszary wymagające poprawy i optymalizacji. Analizujemy potencjał ruchu i wzrostów.',
  },
  {
    number: '03',
    title: 'Budowa strategii',
    desc: 'Tworzymy strategię SEO i planujemy poszczególne etapy prac. Dobieramy najlepsze dedykowane rozwiązania.',
  },
  {
    number: '04',
    title: 'Prace on-site i off-site',
    desc: 'Wykonujemy optymalizację: SEO, UX/UI. Uruchamiamy proces link buildingu oraz systematycznych działań technicznych i content marketingowych.',
  },
  {
    number: '05',
    title: '100% SEO',
    desc: 'Kontynuujemy zaplanowaną strategię SEO. Stale monitorujemy parametry techniczne witryny, stan indeksu i odpowiednio reagujemy na zmiany.',
  },
];
---

<section id="proces" class="bg-gray-100 px-4 sm:px-6 lg:px-8 py-24 lg:py-32 overflow-hidden">
  <div class="max-w-[1200px] mx-auto">
    <div class="mb-16">
      <SectionHeader label="JAK DZIAŁAMY" title="Sprawdzony proces,<br />mierzalne rezultaty" />
    </div>

    <!-- Mobile: vertical, Desktop: horizontal timeline -->
    <div class="relative">

      <!-- Desktop horizontal line -->
      <div
        class="hidden lg:block absolute h-[2px] bg-gray-300"
        style="top: calc(3.5rem + 0.625rem); left: calc(10% + 0.5rem); right: calc(10% + 0.5rem);"
      ></div>

      <div class="flex flex-col lg:flex-row">
        {steps.map((step, i) => (
          <div
            class="flex-1 flex lg:flex-col items-start lg:items-center gap-6 lg:gap-0 py-8 lg:py-0 border-b lg:border-b-0 border-gray-300 last:border-b-0 lg:px-4 lg:text-center"
            data-reveal="fade-up"
            data-reveal-delay={`${i * 100}`}
          >
            <!-- Number + dot column (mobile) / Number above dot (desktop) -->
            <div class="flex flex-col items-center gap-1 flex-shrink-0 lg:w-full">
              <span class="font-display text-[2.5rem] lg:text-[3rem] font-black text-accent leading-none italic">
                {step.number}
              </span>
              <!-- Dot -->
              <div class="w-5 h-5 rounded-full bg-accent border-4 border-gray-100 relative z-10 hidden lg:block"></div>
            </div>

            <!-- Content -->
            <div class="lg:mt-6">
              <h3 class="font-display text-[1.2rem] lg:text-[1.15rem] font-bold mb-2 leading-tight">
                {step.title}
              </h3>
              <p class="text-gray-500 leading-[1.7] text-[0.9rem]">
                {step.desc}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
