---
import type { BlogPost } from '../../lib/wordpress';

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;

// Generuj gwiazdki na podstawie ratingu
function generateStars(rating: number): string[] {
  const stars: string[] = [];
  const fullStars = Math.floor(rating);
  const hasHalfStar = rating % 1 >= 0.5;
  
  for (let i = 0; i < fullStars; i++) {
    stars.push('full');
  }
  
  if (hasHalfStar) {
    stars.push('half');
  }
  
  while (stars.length < 5) {
    stars.push('empty');
  }
  
  return stars;
}

const stars = generateStars(post.rating);
---

<article class="bg-white rounded-lg border border-gray-100 p-6 shadow-sm hover:shadow-md transition-shadow duration-300 flex flex-col h-full">
  <!-- Data -->
  <div class="flex items-center gap-2 text-gray-500 text-sm mb-4">
    <svg 
      xmlns="http://www.w3.org/2000/svg" 
      width="16" 
      height="16" 
      viewBox="0 0 24 24" 
      fill="none" 
      stroke="currentColor" 
      stroke-width="2" 
      stroke-linecap="round" 
      stroke-linejoin="round"
      class="text-gray-400"
    >
      <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
      <line x1="16" y1="2" x2="16" y2="6"></line>
      <line x1="8" y1="2" x2="8" y2="6"></line>
      <line x1="3" y1="10" x2="21" y2="10"></line>
    </svg>
    <time datetime={post.date}>{post.formattedDate}</time>
  </div>
  
  <!-- Tytuł -->
  <h3 class="flex-grow">
    <a 
      href={post.link}
      target="_blank"
      rel="noopener noreferrer"
      class="text-accent font-semibold text-lg leading-tight hover:underline underline-offset-2 transition-all"
    >
      {post.title}
    </a>
  </h3>
  
  <!-- Gwiazdki -->
  <div class="flex items-center gap-0.5 mt-4 mb-4">
    {stars.map((star) => (
      <svg 
        xmlns="http://www.w3.org/2000/svg" 
        width="18" 
        height="18" 
        viewBox="0 0 24 24" 
        class={star === 'empty' ? 'text-gray-300' : 'text-amber-400'}
        fill={star === 'empty' ? 'none' : 'currentColor'}
        stroke="currentColor"
        stroke-width="1.5"
      >
        {star === 'half' ? (
          <>
            <defs>
              <linearGradient id={`half-star-${post.id}`}>
                <stop offset="50%" stop-color="currentColor" />
                <stop offset="50%" stop-color="transparent" />
              </linearGradient>
            </defs>
            <polygon 
              points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"
              fill={`url(#half-star-${post.id})`}
            />
          </>
        ) : (
          <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
        )}
      </svg>
    ))}
  </div>
  
  <!-- Autor i czas czytania -->
  <div class="flex items-center gap-4 text-sm text-gray-500 pt-2 border-t border-gray-100">
    <!-- Autor -->
    <div class="flex items-center gap-1.5">
      <svg 
        xmlns="http://www.w3.org/2000/svg" 
        width="14" 
        height="14" 
        viewBox="0 0 24 24" 
        fill="none" 
        stroke="currentColor" 
        stroke-width="2" 
        stroke-linecap="round" 
        stroke-linejoin="round"
        class="text-gray-400"
      >
        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
        <circle cx="12" cy="7" r="4"></circle>
      </svg>
      <span>{post.author}</span>
    </div>
    
    <!-- Czas czytania -->
    <div class="flex items-center gap-1.5">
      <svg 
        xmlns="http://www.w3.org/2000/svg" 
        width="14" 
        height="14" 
        viewBox="0 0 24 24" 
        fill="none" 
        stroke="currentColor" 
        stroke-width="2" 
        stroke-linecap="round" 
        stroke-linejoin="round"
        class="text-gray-400"
      >
        <circle cx="12" cy="12" r="10"></circle>
        <polyline points="12 6 12 12 16 14"></polyline>
      </svg>
      <span>{post.readingTime} min.</span>
    </div>
  </div>
</article>
