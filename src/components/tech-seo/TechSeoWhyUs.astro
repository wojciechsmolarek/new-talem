---
import SectionHeader from '../ui/SectionHeader.astro';
---

<section class="bg-white px-4 sm:px-6 lg:px-8 py-24 lg:py-32 border-t border-gray-100">
  <div class="max-w-[1400px] mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <!-- Left column - Text -->
      <div>
        <div class="mb-10">
          <SectionHeader label="CO ZYSKUJESZ" title="Dlaczego warto<br />z nami współpracować" />
        </div>

        <p class="text-[1rem] lg:text-[1.1rem] leading-[1.8] text-gray-600 mb-10 w-full italic">
          Każdy z powyższych obszarów Technicznego SEO działa na przekroju całego sklepu
          internetowego - od struktury i indeksacji, przez wydajność i bezpieczeństwo, po wsparcie
          dla treści i linków.
        </p>

        <ul class="flex flex-col gap-5">
          <li class="flex items-start gap-3">
            <div
              class="flex-shrink-0 w-6 h-6 rounded-full bg-accent/10 flex items-center justify-center mt-1"
            >
              <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="3"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="text-accent"
              >
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
            </div>
            <span class="text-[0.95rem] lg:text-[1.05rem] text-gray-700 leading-relaxed">
              Nasze działania opierają się na <b
                >wieloletnim doświadczeniu w technicznym SEO dla e-commerce</b
              >, sprawdzonych praktykach i realnych wdrożeniach.
            </span>
          </li>

          <li class="flex items-start gap-3">
            <div
              class="flex-shrink-0 w-6 h-6 rounded-full bg-accent/10 flex items-center justify-center mt-1"
            >
              <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="3"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="text-accent"
              >
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
            </div>
            <span class="text-[0.95rem] lg:text-[1.05rem] text-gray-700 leading-relaxed">
              Znamy nie tylko teorię, ale i <b>praktyczne rozwiązania, potwierdzone case studies</b
              >, które pokazują, jak optymalizacja techniczna wpływa na wzrost ruchu, konwersji i
              przychodów.
            </span>
          </li>

          <li class="flex items-start gap-3">
            <div
              class="flex-shrink-0 w-6 h-6 rounded-full bg-accent/10 flex items-center justify-center mt-1"
            >
              <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="3"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="text-accent"
              >
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
            </div>
            <span class="text-[0.95rem] lg:text-[1.05rem] text-gray-700 leading-relaxed">
              Dzięki współpracy z nami Twój sklep jest przygotowany nie tylko na bieżące wyzwania
              techniczne, ale również na <b
                >stabilny i długofalowy rozwój widoczności oraz sprzedaży z ruchu organicznego</b
              >.
            </span>
          </li>
        </ul>
      </div>

      <!-- Right column - Decorative graphic -->
      <div class="relative h-[400px] lg:h-[500px] hidden lg:block">
        <!-- Large pale circle -->
        <div
          class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[350px] h-[350px] rounded-full bg-accent/5 opacity-60"
        >
        </div>

        <!-- Medium circle with border -->
        <div
          class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 translate-x-[40px] translate-y-[-30px] w-[280px] h-[280px] rounded-full border-2 border-accent/20 opacity-40"
        >
        </div>

        <!-- Main solid circle -->
        <div
          class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 translate-x-[-20px] translate-y-[20px] w-[220px] h-[220px] rounded-full bg-accent shadow-2xl flex items-center justify-center"
        >
          <svg
            class="w-16 h-16 text-white"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            stroke-width="1.5"
          >
            <path
              d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
            <path
              d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </div>

        <!-- Small top-right circle -->
        <div
          class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 translate-x-[120px] translate-y-[-120px] w-[140px] h-[140px] rounded-full border-2 border-accent/15"
        >
        </div>
      </div>
    </div>
  </div>
</section>
