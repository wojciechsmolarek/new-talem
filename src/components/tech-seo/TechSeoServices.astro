---
import SectionHeader from '../ui/SectionHeader.astro';

const services = [
  {
    number: '01',
    title: 'Projektowanie architektury witryny',
    description:
      'Tworzymy logiczna strukture strony i kategorii, aby wyszukiwarki latwo rozumialy Twoj serwis, a uzytkownicy szybko znajdowali produkty i informacje.',
    icon: 'sitemap',
  },
  {
    number: '02',
    title: 'Optymalizacja indeksacji i crawl budgetu',
    description:
      'Dbamy, aby roboty Google odwiedzaly najwazniejsze strony Twojego serwisu, eliminujac strony niskiej wartosci i bledy w indeksowaniu.',
    icon: 'search',
  },
  {
    number: '03',
    title: 'Core Web Vitals i wydajnosc',
    description:
      'Poprawiamy szybkosc ladowania, stabilnosc wizualna i interaktywnosc strony - zarowno na desktopie, jak i mobile - co przekłada się na lepsze doswiadczenie uzytkownikow i wyzsze pozycje w Google.',
    icon: 'speed',
  },
  {
    number: '04',
    title: 'Duplikacja tresci i adresow URL',
    description:
      'Eliminujemy powielajace sie strony i tresci, aby wyszukiwarki nie tracily czasu na indeksowanie duplikatow i prawidlowo przypisywaly wartosc SEO do wlasciwych adresow.',
    icon: 'duplicate',
  },
  {
    number: '05',
    title: 'Dane strukturalne i rich snippets',
    description:
      'Wdrazamy znaczniki (structured data), ktore pomagaja wyszukiwarkom lepiej rozumiec zawartosc strony, zwiekszajac szanse na atrakcyjne wyniki w SERP-ach, np. z ocenami, FAQ czy informacjami o produktach.',
    icon: 'code',
  },
];
---

<section id="uslugi-tech" class="bg-white px-4 sm:px-6 lg:px-8 py-24 lg:py-32">
  <div class="max-w-[1400px] mx-auto">
    <!-- Header -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 mb-20">
      <SectionHeader
        label="CO ROBIMY"
        title="Co robimy w ramach<br />Technicznego SEO"
      />
      <div class="flex items-end">
        <p class="text-[0.95rem] lg:text-[1.05rem] leading-[1.8] text-gray-600 max-w-[520px]">
          Dzieki naszym dzialaniom Twoj serwis dziala szybciej, jest przyjazny dla uzytkownikow
          i latwy do indeksowania przez Google.
        </p>
      </div>
    </div>

    <!-- Service cards grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        services.map((service) => (
          <div class="bg-white border-2 border-gray-200 rounded-2xl p-8 lg:p-10 relative transition-all duration-300 hover:border-accent hover:-translate-y-2 hover:shadow-2xl group">
            <div class="flex items-center gap-4 mb-6">
              <div class="w-12 h-12 rounded-xl bg-accent/5 flex items-center justify-center group-hover:bg-accent group-hover:text-white transition-colors">
                <svg
                  class="w-5 h-5 text-accent group-hover:text-white transition-colors"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  stroke-width="1.5"
                >
                  <path d="M13 10V3L4 14h7v7l9-11h-7z" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </div>
              <span class="font-mono text-[0.85rem] font-bold text-gray-400">
                {service.number}
              </span>
            </div>

            <h3 class="font-display text-[1.2rem] lg:text-[1.35rem] font-bold mb-4 leading-[1.3]">
              {service.title}
            </h3>

            <p class="text-gray-600 leading-[1.7] text-[0.92rem]">
              {service.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
