---
import SectionHeader from '../ui/SectionHeader.astro';

const additionalServices = [
  {
    number: '01',
    title: 'Zarządzanie przekierowaniami i błędami 4xx/5xx',
    description:
      'Monitorujemy i poprawiamy błędy strony oraz przekierowania, aby użytkownicy i roboty Google nie napotykali martwych linków, co chroni widoczność i zapewnia płynność ruchu.',
  },
  {
    number: '02',
    title: 'Optymalizacja plików i zasobów strony',
    description:
      'Kompresujemy obrazy, konfigurujemy cache, wdrażamy lazy loading i optymalizujemy pliki CSS/JS, aby strona ładowała się szybciej, a Core Web Vitals osiągały lepsze wyniki.',
  },
  {
    number: '03',
    title: 'Obsługa plików robots.txt, sitemap.xml i hreflang',
    description:
      'Dbamy o poprawną konfigurację plików sterujących indeksacją i map strony oraz oznaczenia wielojęzyczne (hreflang), co pozwala Google prawidłowo indeksować wszystkie wersje sklepu i stron kategorii.',
  },
  {
    number: '04',
    title: 'Audyt bezpieczeństwa',
    description:
      'Sprawdzamy poprawność certyfikatów HTTPS, zabezpieczenia przed spamem i atakami oraz konfigurację serwera, aby strona była bezpieczna i wiarygodna dla użytkowników oraz wyszukiwarek.',
  },
  {
    number: '05',
    title: 'Optymalizacja renderowania i ładowania zasobów',
    description:
      'Analizujemy sposób, w jaki przeglądarka pobiera i przetwarza zasoby potrzebne do wyświetlenia strony. Eliminujemy elementy blokujące renderowanie i optymalizujemy kolejność ładowania plików, aby użytkownik jak najszybciej zobaczył treść strony (fonty, kolejności ładowania zasobów, lazy loading obrazów, wideo oraz widgetów, implementacja LQIP, skeleton placeholders dla elementów dynamicznych).',
  },
  {
    number: '06',
    title: 'Optymalizacja skryptów zewnętrznych i narzędzi analitycznych',
    description:
      'Kontrolujemy wpływ zewnętrznych skryptów na wydajność strony. Dzięki temu narzędzia marketingowe i analityczne nie spowalniają działania sklepu. Optymalizujemy działania skryptów zewnętrznych, Google Tag Manager, Google Analytics oraz innych skryptów zewnętrznych tak, aby nie blokowały działania strony.',
  },
  {
    number: '07',
    title: 'Analiza wydajności sieci i serwera',
    description:
      'Analizujemy opóźnienia sieciowe i czas odpowiedzi serwera, aby zidentyfikować wąskie gardła wpływające na szybkość ładowania strony, m.in.: analiza czasu odpowiedzi serwera (TTFB), czasu komunikacji z serwerem (RTT), zależności między opóźnieniami sieci a czasem odpowiedzi serwera, opóźnień sieciowych i jakości połączenia, procesu nawiązywania połączenia (DNS, TCP, TLS).',
  },
  {
    number: '08',
    title: 'Optymalizacja warstwy sieciowej i serwerowej',
    description:
      'Optymalizujemy sposób dostarczania danych z serwera do przeglądarki, aby strona była szybka i stabilna niezależnie od lokalizacji użytkownika: kompresja zasobów (gzip, brotli), konfiguracja protokołów komunikacji (HTTP/2, HTTP/3), optymalizacja połączeń szyfrowanych (TLS / SSL), konfiguracja pamięci podręcznej przeglądarki (cache), wdrażanie sieci dostarczania treści (CDN, np. Cloudflare), optymalizacja ponownego ładowania strony dzięki pamięci przeglądarki (bfcache), wdrażanie mechanizmów przewidywania nawigacji użytkownika (Speculation Rules API.',
  },
];
---

<section class="bg-white text-black px-4 sm:px-6 lg:px-8 py-24 lg:py-32">
  <div class="max-w-[1400px] mx-auto">
    <!-- Header -->
    <div class="text-center mb-20">
      <SectionHeader
        label="DODATKOWE DZIAŁANIA"
        title="Inne działania techniczne<br />i integracja z obszarami SEO"
        centered
      />
      <p class="text-[0.95rem] lg:text-[1.05rem] leading-[1.8] text-gray-600 w-full mx-auto mt-6">
        Kompleksowa optymalizacja techniczna wykracza poza podstawy - obejmuje bezpieczeństwo,
        zarządzanie zasobami i pełna konfiguracja indeksacji.
      </p>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-16 gap-y-12">
      {
        additionalServices.map((service) => (
          <div class="flex gap-6 items-start" data-reveal>
            <div class="flex-shrink-0 w-14 h-14 rounded-xl bg-accent flex items-center justify-center">
              <span class="font-mono text-[1rem] font-bold text-white">{service.number}</span>
            </div>
            <div>
              <h3 class="font-display text-[1.2rem] lg:text-[1.35rem] font-bold mb-3 leading-[1.3] text-black">
                {service.title}
              </h3>
              <p class="text-gray-600 leading-[1.7] text-[0.92rem]">{service.description}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
