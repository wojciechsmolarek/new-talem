---
import '../styles/global.css';
import GoogleAnalytics from '../components/GoogleAnalytics.astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import cookieConsentConfig from '../config/cookieconsent.js';
import 'vanilla-cookieconsent/dist/cookieconsent.css';
import '../styles/cookieconsent-overrides.css';

interface Props {
  title?: string;
  description?: string;
  schema?: Record<string, unknown>[];
}

const {
  title = 'TALEM - Agencja SEO | Wzrost Oparty na Danych',
  description = 'Profesjonalna agencja SEO. Zwiększamy widoczność i ruch organiczny. Mierzalne wyniki, transparentne raportowanie.',
  schema,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname.replace(/\.html$/, ''), Astro.site);
---

<!doctype html>
<html lang="pl" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="robots" content="index, follow" />
    <meta name="description" content={description} />

    <GoogleAnalytics />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://www.talem.eu/og-image.jpg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="pl_PL" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content="https://www.talem.eu/og-image.jpg" />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon.ico" />

    <!-- Schema.org Markup -->
    {
      schema && schema.length > 0 && (
        <Fragment
          set:html={`<script type="application/ld+json">${JSON.stringify({ '@context': 'https://schema.org', '@graph': schema })}</script>`}
        />
      )
    }
  </head>
  <body>
    <slot />
    <SpeedInsights />
    <script>
      import '../scripts/scroll-reveal';
    </script>

    <script is:inline define:vars={{ cookieConsentConfig }}>
      window.__cookieConsentConfig = cookieConsentConfig;
    </script>

    <script>
      import '../scripts/cookieconsent-init';
    </script>
  </body>
</html>
